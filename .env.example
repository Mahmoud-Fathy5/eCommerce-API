# Database Connection URL (PostgreSQL)
# For local databases: postgresql://username:password@localhost:5432/ecommerce?schema=public
# For cloud providers like Neon: postgresql://neondb_owner:YOUR_PASSWORD@ep-winter-flower.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/ecommerce?schema=public"

# JSON Web Token Secret Strings
# You can generate a strong secret string using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET="your_access_token_secret_string"
REFRESH_TOKEN_SECRET="your_refresh_token_secret_string"

# Application Environment (development / production)
NODE_ENV="development"
